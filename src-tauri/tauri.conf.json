{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nettle",
  "version": "0.1.1",
  "identifier": "dev.flo.nettle",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "nettle",
        "width": 1240,
        "height": 806,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}